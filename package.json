{
	"name": "factorio-blueprint-playground",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"preinstall": "npx only-allow pnpm",
		"dev": "vp dev",
		"dev:pages": "wrangler pages dev --proxy=5173 --port=8788",
		"dev:functions": "wrangler pages dev . --port=8788",
		"preview": "wrangler pages dev dist --port 5174",
		"generate:routes": "tsr generate",
		"build": "pnpm run generate:routes && tsgo && vp build && wrangler pages functions build",
		"build:types": "pnpm run generate:routes && tsgo --noEmit --project tsconfig.routes.json",
		"oxlint": "vp lint . --fix",
		"oxlint:ci": "vp lint . --format github",
		"fmt": "vp fmt",
		"fmt:ci": "vp fmt --check",
		"fallow": "fallow fix --yes",
		"fallow:ci": "fallow dead-code",
		"typecheck": "pnpm run generate:routes && tsgo --noEmit",
		"test": "node node_modules/vitest/dist/cli.js",
		"test:ui": "node node_modules/vitest/dist/cli.js --ui",
		"test:run": "node node_modules/vitest/dist/cli.js run",
		"test:coverage": "node node_modules/vitest/dist/cli.js run --coverage",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build",
		"prepare": "vp config"
	},
	"dependencies": {
		"@sentry/react": "^10.57.0",
		"@tanstack/react-query": "^5.101.0",
		"@tanstack/react-query-devtools": "^5.101.0",
		"@tanstack/react-router": "^1.170.15",
		"date-fns": "^4.4.0",
		"dexie": "^4.4.3",
		"dexie-react-hooks": "^4.4.0",
		"fflate": "^0.8.3",
		"json5": "^2.2.3",
		"lucide-react": "^1.18.0",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"react-error-boundary": "^6.1.2",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@chromatic-com/storybook": "^5.2.1",
		"@cloudflare/workers-types": "^4.20260615.1",
		"@playwright/test": "^1.60.0",
		"@storybook/addon-a11y": "^10.4.5",
		"@storybook/addon-docs": "^10.4.4",
		"@storybook/addon-onboarding": "^10.4.4",
		"@storybook/addon-vitest": "^10.4.5",
		"@storybook/react-vite": "^10.4.5",
		"@tanstack/react-router-devtools": "^1.167.0",
		"@tanstack/router-cli": "^1.167.17",
		"@tanstack/router-plugin": "^1.168.18",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/node": "^25.9.3",
		"@types/pngjs": "^6.0.5",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@typescript/native-preview": "^7.0.0-dev.20260615.1",
		"@vitejs/plugin-react": "^6.0.2",
		"@vitest/browser-playwright": "^4.1.9",
		"@vitest/coverage-v8": "^4.1.9",
		"eslint": "^10.4.1",
		"eslint-plugin-storybook": "^10.4.4",
		"fallow": "^2.95.0",
		"jsdom": "^29.1.1",
		"markdownlint-cli2": "^0.22.1",
		"pixelmatch": "^7.2.0",
		"playwright": "^1.61.0",
		"pngjs": "^7.0.0",
		"sharp": "^0.35.1",
		"storybook": "^10.4.3",
		"tsx": "^4.22.4",
		"typescript": "~6.0.3",
		"vite": "catalog:",
		"vite-plus": "catalog:",
		"vitest": "catalog:",
		"wrangler": "^4.100.0"
	},
	"packageManager": "pnpm@11.1.1"
}
